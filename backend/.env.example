# ── Server ─────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MySQL ──────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=skillbarter

# ── JWT ────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# ── CORS ───────────────────────────────────
CLIENT_URL=http://localhost:5173
