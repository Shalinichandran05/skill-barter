# ── Server ─────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Supabase PostgreSQL ─────────────────────
# Get this from: Supabase Dashboard → Settings → Database → Connection string (Transaction mode)
# Format: postgresql://postgres.[ref]:[password]@[host]:6543/postgres
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-region.pooler.supabase.com:6543/postgres

# ── JWT ────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# ── CORS ───────────────────────────────────
CLIENT_URL=http://localhost:5173
